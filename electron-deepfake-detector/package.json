{
    "name": "deepfake-detector",
    "version": "1.0.1",
    "description": "Deepfake Detector Application",
    "main": "main.js",
    "scripts": {
      "start": "electron .",
      "build": "electron-builder",
      "pack-win": "electron-builder --win",
      "prepare" : "node ../prepare.js"
    },
    "author": "Anton Hantschmann",
    "license": "MIT",
    "devDependencies": {
      "electron": "^25.0.0",
      "electron-builder": "^24.0.0"
    },
    "build": {
      "appId": "com.hantschmann.deepfakedetector",
      "productName": "Deepfake Detector",
      "directories": {
        "output": "dist"
      },
      "files": [
        "!node_modules/**/*",
        "!src/**/*",
        "main.js",
        "preload.js",
        "package.json",
        "web/**/*",
        "resources/**/*"
      ],
      "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
      "win": {
  "target": "nsis",
  "icon": "resources/icon.ico"
  },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": false,
      "uninstallDisplayName": "${productName} ${version}",
      "deleteAppDataOnUninstall": true
    }
    }
  }